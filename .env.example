# Twitch bot account name (without @)
TWITCH_BOT_USERNAME=your_bot_username

# OAuth token for the bot account. Keep the `oauth:` prefix.
TWITCH_OAUTH_TOKEN=oauth:replace_with_your_token

# Channel to monitor (without #)
TWITCH_CHANNEL=channel_to_monitor

# Set to true to show tmi.js connection logs.
TWITCH_DEBUG=false

# Temporary test setting: also process messages sent by this bot account.
# Set this to false after testing to ignore the bot's own messages.
PROCESS_OWN_MESSAGES=true

# Set to true only after the translation model has been downloaded once.
# This prevents any further model downloads and uses the local model cache only.
LOCAL_MODELS_ONLY=false
