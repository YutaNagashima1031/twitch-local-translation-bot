{
  "name": "twitch-local-translation-bot",
  "version": "0.1.0",
  "private": true,
  "description": "A Twitch chat bot that detects and translates messages locally into Japanese.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "tsx --test src/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.2",
    "dotenv": "^16.6.1",
    "franc": "^6.2.0",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/tmi.js": "^1.8.6",
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
